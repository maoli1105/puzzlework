# ============================================================
# PuzzleWork バックエンド 環境変数
# .env.example をコピーして .env を作成してください
# cp .env.example .env
# ============================================================

# サーバーポート
PORT=3002

# PostgreSQL 接続文字列
# ローカル例: postgresql://username@localhost:5432/puzzlework
# 本番例:    postgresql://user:password@host:5432/puzzlework
DATABASE_URL=postgresql://username@localhost:5432/puzzlework

# JWT署名シークレット（本番は必ずランダムな文字列に変更）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_IN_PRODUCTION

# フロントエンドURL（CORS設定に使用）
FRONTEND_URL=http://localhost:3000

# Resend メールサービス（省略可 — 未設定時はメール送信をスキップ）
# https://resend.com で取得
RESEND_API_KEY=

# 送信元メールアドレス（Resend で検証済みのドメインのアドレス）
EMAIL_FROM=

# NODE_ENV（本番環境では production に設定）
NODE_ENV=development
